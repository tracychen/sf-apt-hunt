# Signed-in persistence: Better Auth + Google OAuth + Postgres.
DATABASE_URL=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3333
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Listing geocoding. Required before enabling real listing pin geocoding in production.
GOOGLE_MAPS_API_KEY=
GEOCODE_NONCE_SECRET=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional AI/model configuration. Users still enter their OpenAI API key in the browser UI.
OPENAI_MODEL=

# Optional public map tile configuration. These values are exposed to the browser.
NEXT_PUBLIC_TILE_URL=
NEXT_PUBLIC_TILE_ATTRIBUTION=
